{
  "name": "ocr-extractor-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:client": "vite --host 0.0.0.0 --port 3001",
    "build": "tsc -p server/tsconfig.json && vite build",
    "start": "node dist-server/index.js",
    "lint": "eslint . --ext ts,tsx"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "canvas": "^3.2.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "pdfjs-dist": "^5.5.207",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
